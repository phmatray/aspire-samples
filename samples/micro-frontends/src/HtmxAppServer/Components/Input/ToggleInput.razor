<div class="@($"form-control w-full {ContainerStyle}")">
  <label class="label cursor-pointer">
    <span class="@($"label-text text-base-content {LabelStyle}")">@LabelTitle</span>
    <input type="checkbox" class="toggle" value="@Value" @onchange="UpdateToggleValue" />
  </label>
</div>

@code {
  [Parameter]
  public string LabelTitle { get; set; }

  [Parameter]
  public string LabelStyle { get; set; }

  [Parameter]
  public string ContainerStyle { get; set; }

  [Parameter]
  public bool DefaultValue { get; set; }

  [Parameter]
  public EventCallback<(string updateType, bool value)> UpdateFormValue { get; set; }

  [Parameter]
  public string UpdateType { get; set; }

  private bool Value { get; set; }

  protected override void OnInitialized()
  {
    Value = DefaultValue;
  }

  private async Task UpdateToggleValue(ChangeEventArgs e)
  {
    Value = !Value; // Toggle the value
    await UpdateFormValue.InvokeAsync((UpdateType, Value));
  }
}
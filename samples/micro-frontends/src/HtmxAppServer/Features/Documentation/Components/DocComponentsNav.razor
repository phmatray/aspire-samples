<ul class="menu w-56 mt-10 text-sm">
  <li class="menu-title">
    <span>Components</span>
  </li>
  @foreach (var item in NavItems)
  {
    <li class="@GetItemClass(item)" @onclick="@(() => ScrollToSection(item))">
      <a>@item.Name</a>
    </li>
  }
</ul>

@code {
  
  [Parameter]
  public int ActiveIndex { get; set; }

  private List<NavItem> NavItems { get; set; }

  protected override void OnParametersSet()
  {
    NavItems =
    [
      new NavItem { Name = "Typography", IsActive = ActiveIndex == 1 },
      new NavItem { Name = "Form Input", IsActive = ActiveIndex == 2 },
      new NavItem { Name = "Cards", IsActive = ActiveIndex == 3 },
    ];
  }

  private void ScrollToSection(NavItem item)
  {
    foreach (var navItem in NavItems)
    {
      navItem.IsActive = navItem == item;
    }

    // JavaScript interop to scroll
    // JSRuntime.InvokeVoidAsync("eval", $"document.getElementById('feature{(NavItems.IndexOf(item) + 1)}').scrollIntoView({{behavior: 'smooth'}})");
  }

  private string GetItemClass(NavItem item) => item.IsActive ? "bordered" : "";
}
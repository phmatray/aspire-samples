@using HtmxAppServer.Features.Transactions.Models
@inherits HtmxComponentBase<TransactionsEndpoint.TransactionsParameters>

<MainLayout Title="Transaction">
  <TitleCard title="Recent Transactions" topMargin="mt-2">
  
    @* Team Member list in table format loaded constant *@
    <div class="overflow-x-auto w-full">
      <table class="table w-full">
        <thead>
        <tr>
          <th>Name</th>
          <th>Email Id</th>
          <th>Location</th>
          <th>Amount</th>
          <th>Transaction Date</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var transaction in _transactions)
        {
          <tr key=@transaction.Id>
            <td>
              <div class="flex items-center space-x-3">
                <div class="avatar">
                  <div class="mask mask-circle w-12 h-12">
                    <img src=@transaction.Avatar alt="Avatar"/>
                  </div>
                </div>
                <div>
                  <div class="font-bold">@transaction.Name</div>
                </div>
              </div>
            </td>
            <td>@transaction.Email</td>
            <td>@transaction.Location</td>
            <td>@transaction.Amount</td>
            <td>@transaction.Date.ToShortDateString()</td>
          </tr>
        }
        </tbody>
      </table>
    </div>
  </TitleCard>
</MainLayout>

@code
{

  private readonly List<TransactionModel> _transactions =
  [
    new TransactionModel(
      "1",
      "John Doe",
      "john.doe@example.com",
      "Antwerpen",
      "https://reqres.in/img/faces/1-image.jpg",
      100,
      new DateTime(2021, 10, 10)),
    new TransactionModel(
      "2",
      "Jane Doe",
      "jane.doe@example.com",
      "Brussels",
      "https://reqres.in/img/faces/2-image.jpg",
      150,
      new DateTime(2021, 10, 10)),
  ];
}

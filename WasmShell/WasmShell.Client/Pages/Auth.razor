@page "/auth"

@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<PageTitle>Auth</PageTitle>

<MudContainer Class="mt-4 px-8" MaxWidth="MaxWidth.False">
    <MudText Typo="Typo.h4">You are authenticated</MudText>

    <AuthorizeView>
        Hello @context.User.Identity?.Name!
    </AuthorizeView>
</MudContainer>
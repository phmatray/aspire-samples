<div class="@ContainerClass">
      
  <section class="@SectionClass">
                
    <div class="relative  pb-5 flex flex-col  h-full">
                        
      @* Header *@
      <div class="navbar   flex pl-4 pr-4   shadow-md ">
        <button class="float-left btn btn-circle btn-outline btn-sm" @onClick="@Close">
          <XMarkIcon class="h-5 w-5"/>
        </button>
        <span class="ml-2 font-bold text-xl">@Header</span>
      </div>


      @* ------------------ Content Start ------------------ *@
      <div class="overflow-y-scroll pl-4 pr-4">
        <div class="flex flex-col w-full">
        </div>
      </div>
      @* ------------------ Content End ------------------ *@
    </div>

  </section>

  <section class=" w-screen h-full cursor-pointer " @onClick="@Close" ></section>
</div>

@code {

  [Parameter]
  public bool IsOpen { get; set; }
  
  private string Header { get; set; }
  
  private void Close(){}

  public string ContainerClass
    => "fixed overflow-hidden z-20 bg-gray-900 bg-opacity-25 inset-0 transform ease-in-out "
       + (IsOpen 
         ? " transition-opacity opacity-100 duration-500 translate-x-0 "
         : " transition-all delay-500 opacity-0 translate-x-full ");

  public string SectionClass
    => "w-80 md:w-96  right-0 absolute bg-base-100 h-full shadow-xl delay-400 duration-500 ease-in-out transition-all transform  "
       + (IsOpen ? " translate-x-0 " : " translate-x-full ");

}
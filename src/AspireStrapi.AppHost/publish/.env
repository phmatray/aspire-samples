# Container image name for frontend-blog (pre-built via `dotnet publish -t:PublishContainer`)
FRONTEND_BLOG_IMAGE=aspirestrapi-frontend-blog:local

# Default container port for frontend-blog
FRONTEND_BLOG_PORT=8080

# Parameter postgres-password
POSTGRES_PASSWORD=strapi

# Parameter postgres-username
POSTGRES_USERNAME=strapi

# Parameter strapi-admin-jwt-secret
STRAPI_ADMIN_JWT_SECRET=yt+WWFQLKJWVA0mGh9brCw==

# Parameter strapi-api-token-salt
STRAPI_API_TOKEN_SALT=X2i3Po24w8EDsBj7QHktaw==

# Parameter strapi-app-keys
STRAPI_APP_KEYS=FO7XR1+fPZ2EY6Oc12fizA==,oB6b+m7JHXkrUfn3rKCe2Q==

# Parameter strapi-encryption-key
STRAPI_ENCRYPTION_KEY=ovfPuQPxgP9ZMx5YxURZ6g==


@* Accessible error state with an optional retry action. *@
<div class="alert alert-danger d-flex flex-column gap-2" role="alert">
    <div>
        <strong>Couldn't load this content.</strong>
        <span class="d-block">@Message</span>
    </div>
    @if (OnRetry.HasDelegate)
    {
        <div>
            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="OnRetry">
                Try again
            </button>
        </div>
    }
</div>

@code {
    [Parameter]
    public string Message { get; set; } =
        "The Strapi GraphQL API may be starting up or unreachable. Make sure the Strapi service is running, then retry.";

    /// <summary>Optional callback that re-runs the failed fetch.</summary>
    [Parameter]
    public EventCallback OnRetry { get; set; }
}

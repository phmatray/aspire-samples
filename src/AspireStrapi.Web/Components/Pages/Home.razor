@page "/"
@rendermode InteractiveServer
@inject IContentService ContentService

<PageTitle>Strapi headless CMS demo</PageTitle>

<section class="cms-hero">
    <p class="cms-eyebrow">Blazor · .NET Aspire · Strapi · GraphQL</p>
    <h1>A headless CMS demo, rendered live by Blazor</h1>
    <p class="lead">
        Content is authored in the <a href="http://localhost:1337/admin" target="_blank" rel="noopener noreferrer">Strapi admin</a>
        and rendered here over GraphQL through a clean hexagonal architecture — the UI depends only on
        application ports.
    </p>
    <div class="cms-hero__actions">
        <a class="btn btn-primary" href="/articles">Browse articles</a>
        <a class="btn btn-outline-secondary" href="/headless-cms">How it works</a>
    </div>
</section>

<section aria-labelledby="latest-heading" class="mt-5">
    <div class="d-flex justify-content-between align-items-baseline">
        <h2 id="latest-heading" class="h4">Latest articles</h2>
        <a href="/articles" class="small">View all &rarr;</a>
    </div>

    @if (_state == LoadState.Loading)
    {
        <LoadingIndicator Message="Loading the latest articles from Strapi…" />
    }
    else if (_state == LoadState.Error)
    {
        <ErrorAlert OnRetry="LoadAsync" />
    }
    else if (_articles is { Count: 0 })
    {
        <div class="alert alert-info" role="status">
            No articles yet. Add one in the
            <a href="http://localhost:1337/admin" target="_blank" rel="noopener noreferrer">Strapi admin</a>.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4 mt-1">
            @foreach (ArticleDto article in _articles!.Take(3))
            {
                <div class="col">
                    <ArticleCard Article="article" />
                </div>
            }
        </div>
    }
</section>

@code {
    private enum LoadState { Loading, Loaded, Error }

    private IReadOnlyList<ArticleDto>? _articles;
    private LoadState _state = LoadState.Loading;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _state = LoadState.Loading;
        try
        {
            _articles = await ContentService.GetArticlesAsync();
            _state = LoadState.Loaded;
        }
        catch
        {
            _state = LoadState.Error;
        }
    }
}

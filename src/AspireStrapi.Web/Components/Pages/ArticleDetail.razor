@page "/articles/{DocumentId}"
@rendermode InteractiveServer
@inject IContentService ContentService

<PageTitle>@(_article?.Title ?? "Article") · Strapi CMS demo</PageTitle>

<p class="mb-3">
    <a href="/articles" class="back-link">&larr; Back to all articles</a>
</p>

@if (_state == LoadState.Loading)
{
    <LoadingIndicator Message="Loading the article from Strapi…" />
}
else if (_state == LoadState.Error)
{
    <ErrorAlert OnRetry="LoadAsync" />
}
else if (_state == LoadState.NotFound || _article is null)
{
    <div class="alert alert-warning" role="status">
        <strong>Article not found.</strong>
        <span class="d-block">
            It may have been unpublished or deleted in the
            <a href="http://localhost:1337/admin" target="_blank" rel="noopener noreferrer">Strapi admin</a>.
        </span>
    </div>
}
else
{
    <article class="article-detail">
        <header class="article-detail__header">
            @if (!string.IsNullOrWhiteSpace(_article.CategoryName))
            {
                <p class="mb-2">
                    <a href="@CategoryUrl" class="text-decoration-none">
                        <span class="badge rounded-pill text-bg-primary">@_article.CategoryName</span>
                    </a>
                </p>
            }

            <h1>@_article.Title</h1>

            @if (!string.IsNullOrWhiteSpace(_article.Description))
            {
                <p class="lead text-body-secondary">@_article.Description</p>
            }

            <div class="article-detail__byline d-flex align-items-center gap-2">
                @if (!string.IsNullOrWhiteSpace(_article.AuthorAvatarUrl))
                {
                    <img src="@_article.AuthorAvatarUrl" class="article-detail__avatar" alt="" loading="lazy" />
                }
                <span class="text-body-secondary">
                    @if (!string.IsNullOrWhiteSpace(_article.AuthorName))
                    {
                        <span>By <strong>@_article.AuthorName</strong></span>
                    }
                    @if (_article.PublishedAt is { } published)
                    {
                        <span> · <time datetime="@published.ToString("yyyy-MM-dd")">@published.ToString("MMMM d, yyyy")</time></span>
                    }
                </span>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(_article.CoverImageUrl))
        {
            <img src="@_article.CoverImageUrl" class="article-detail__cover" alt="@($"Cover image for {_article.Title}")" />
        }

        <div class="article-detail__body">
            @if (!string.IsNullOrWhiteSpace(_article.BodyHtml))
            {
                @((MarkupString)_article.BodyHtml)
            }
            else if (!string.IsNullOrWhiteSpace(_article.Description))
            {
                <p>@_article.Description</p>
            }
            else
            {
                <p class="text-body-secondary"><em>This article has no body content yet.</em></p>
            }
        </div>

        @if (_article.Tags.Count > 0)
        {
            <footer class="article-detail__tags">
                <h2 class="h6 text-uppercase text-body-secondary">Tags</h2>
                <ul class="tag-list" role="list">
                    @foreach (string tag in _article.Tags)
                    {
                        <li><span class="badge text-bg-light border">#@tag</span></li>
                    }
                </ul>
            </footer>
        }
    </article>
}

@code {
    private enum LoadState { Loading, Loaded, NotFound, Error }

    [Parameter]
    public string DocumentId { get; set; } = string.Empty;

    private ArticleDetailDto? _article;
    private LoadState _state = LoadState.Loading;

    private string CategoryUrl =>
        string.IsNullOrWhiteSpace(_article?.CategorySlug)
            ? "/categories"
            : $"/categories?slug={Uri.EscapeDataString(_article!.CategorySlug!)}";

    private string? _loadedId;

    // OnParametersSetAsync fires on first render and on every route-param change,
    // so it is the single load trigger (avoids a duplicate fetch from OnInitialized).
    protected override async Task OnParametersSetAsync()
    {
        if (_loadedId != DocumentId)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync()
    {
        _state = LoadState.Loading;
        _loadedId = DocumentId;
        try
        {
            _article = await ContentService.GetArticleAsync(DocumentId);
            _state = _article is null ? LoadState.NotFound : LoadState.Loaded;
        }
        catch
        {
            _state = LoadState.Error;
        }
    }
}

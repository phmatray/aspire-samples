@page "/"
@rendermode InteractiveServer
@inject IContentService ContentService

<PageTitle>The Headless Press · A Strapi + Blazor folio</PageTitle>

<section class="mx-auto max-w-6xl px-6 pt-16 pb-12 md:pt-24 md:pb-16">
    <p class="kicker rise">Dispatches from a headless CMS</p>
    <h1 class="rise d-1 mt-6 font-display font-semibold tracking-tight leading-[0.92] text-[clamp(3rem,9vw,7rem)]">
        The press that<br/>
        <span class="italic">prints</span> itself<span class="text-vermilion">.</span>
    </h1>
    <div class="mt-8 grid gap-8 md:grid-cols-[1.1fr_0.9fr] md:items-end">
        <p class="rise d-2 max-w-xl text-xl leading-relaxed text-ink-soft">
            Every word is composed in <a class="ink-link" href="http://127.0.0.1:1337/admin" target="_blank" rel="noopener noreferrer">Strapi</a>,
            queried over GraphQL, and set into type by Blazor — live, on each request, through a clean
            hexagonal architecture where the page depends only on application ports.
        </p>
        <div class="rise d-3 flex flex-wrap gap-3 md:justify-end">
            <a class="btn-ink" href="/articles">Read the folio</a>
            <a class="btn-ghost" href="/headless-cms">The colophon</a>
        </div>
    </div>
</section>

<div class="mx-auto max-w-6xl px-6"><hr class="rule"/></div>

<section aria-labelledby="latest-heading" class="mx-auto max-w-6xl px-6 py-14">
    <div class="flex items-end justify-between gap-4 mb-10">
        <div>
            <p class="kicker">The latest</p>
            <h2 id="latest-heading" class="mt-3 font-display text-4xl font-semibold">Fresh off the wire</h2>
        </div>
        <a href="/articles" class="nav-link whitespace-nowrap">All articles →</a>
    </div>

    @if (_state == LoadState.Loading)
    {
        <LoadingIndicator Message="Loading the latest articles from Strapi…" />
    }
    else if (_state == LoadState.Error)
    {
        <ErrorAlert OnRetry="LoadAsync" />
    }
    else if (_articles is { Count: 0 })
    {
        <EmptyNote>No articles yet. Compose one in the <a class="ink-link" href="http://127.0.0.1:1337/admin" target="_blank" rel="noopener noreferrer">Strapi admin</a>.</EmptyNote>
    }
    else
    {
        var featured = _articles![0];
        <a href="/articles/@featured.Id" class="group grid gap-8 md:grid-cols-2 md:items-center rise">
            @if (!string.IsNullOrWhiteSpace(featured.CoverImageUrl))
            {
                <div class="cover aspect-[3/2] order-1 md:order-none"><img src="@featured.CoverImageUrl" alt="" /></div>
            }
            <div>
                <div class="flex items-center gap-3 mb-4">
                    <span class="tag">@(featured.CategoryName ?? "Feature")</span>
                    <span class="meta">Lead story</span>
                </div>
                <h3 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.05] font-semibold">
                    <span class="title-link">@featured.Title</span>
                </h3>
                @if (!string.IsNullOrWhiteSpace(featured.Description))
                {
                    <p class="mt-4 text-lg text-ink-soft leading-relaxed max-w-xl">@featured.Description</p>
                }
                <p class="meta mt-5">@(featured.AuthorName ?? "Staff") @(featured.PublishedAt is { } p ? "· " + p.ToString("MMM d, yyyy") : "")</p>
            </div>
        </a>

        @if (_articles.Count > 1)
        {
            <hr class="rule my-12"/>
            <div class="grid gap-x-10 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
                @foreach (var article in _articles.Skip(1).Take(3))
                {
                    <ArticleCard Article="article" />
                }
            </div>
        }
    }
</section>

@code {
    private enum LoadState { Loading, Loaded, Error }

    private IReadOnlyList<ArticleDto>? _articles;
    private LoadState _state = LoadState.Loading;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _state = LoadState.Loading;
        try
        {
            _articles = await ContentService.GetArticlesAsync();
            _state = LoadState.Loaded;
        }
        catch
        {
            _state = LoadState.Error;
        }
    }
}
